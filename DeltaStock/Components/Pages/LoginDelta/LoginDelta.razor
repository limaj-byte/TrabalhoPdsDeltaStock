@page "/"

<PageTitle>Login - DeltaStock</PageTitle>

<div class="divlog">
    <div class="center-container">
        <div class="squareLogin">
            <h2>🔐 Acesso</h2>
            <input type="text" placeholder="E-mail ou Usuário" id="user" autocomplete="username">
            <input type="password" placeholder="Senha" id="senha" autocomplete="current-password">
            <button type="button" class="logSend">Entrar</button>
            <div class="login-footer">
                <a href="/HomePage">Continuar como Visitante</a>
            </div>
        </div>
    </div>
</div>